{
  "name": "@livraison/identity",
  "version": "0.1.0",
  "private": true,
  "license": "UNLICENSED",
  "description": "Livraison Identity service: auth, users, and tenants.",
  "main": "dist/main.js",
  "scripts": {
    "build": "nest build",
    "start": "node dist/main.js",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main.js",
    "lint": "eslint \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage --runInBand",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:migrate:dev": "prisma migrate dev",
    "clean": "rimraf dist .turbo coverage"
  },
  "dependencies": {
    "@nestjs/common": "10.4.4",
    "@nestjs/config": "3.2.3",
    "@nestjs/core": "10.4.4",
    "@nestjs/jwt": "10.2.0",
    "@nestjs/platform-express": "10.4.4",
    "@nestjs/terminus": "10.2.3",
    "@prisma/client": "5.20.0",
    "argon2": "0.41.1",
    "class-transformer": "0.5.1",
    "class-validator": "0.14.1",
    "helmet": "8.0.0",
    "ioredis": "5.4.1",
    "nestjs-pino": "4.1.0",
    "pino-http": "10.3.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.1",
    "uuid": "10.0.0"
  },
  "devDependencies": {
    "@livraison/eslint-config": "workspace:*",
    "@nestjs/cli": "10.4.5",
    "@nestjs/schematics": "10.1.4",
    "@nestjs/testing": "10.4.4",
    "@types/express": "4.17.21",
    "@types/jest": "29.5.13",
    "@types/node": "20.14.10",
    "@types/uuid": "10.0.0",
    "eslint": "8.57.1",
    "jest": "29.7.0",
    "prisma": "5.20.0",
    "rimraf": "6.0.1",
    "ts-jest": "29.2.5",
    "ts-loader": "9.5.1",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "5.5.4"
  }
}
