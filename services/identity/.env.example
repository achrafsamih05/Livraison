# --- Runtime ---
APP_ENV=dev
HTTP_PORT=3001
LOG_LEVEL=info

# --- Database ---
DATABASE_URL=postgresql://livraison:livraison@localhost:5432/identity?schema=public

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- JWT ---
JWT_ACCESS_SECRET=change-me-access-secret-at-least-32-chars-long
JWT_REFRESH_SECRET=change-me-refresh-secret-at-least-32-chars-long
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000
JWT_ISSUER=livraison-identity
JWT_AUDIENCE=livraison-platform

# --- Security ---
BCRYPT_PEPPER=change-me-optional-pepper
