{
  "name": "@livraison/tracking",
  "version": "0.1.0",
  "private": true,
  "license": "UNLICENSED",
  "description": "Livraison Tracking service: events, timeline, public/internal tracking, real-time updates, audit.",
  "main": "dist/main.js",
  "scripts": {
    "build": "nest build",
    "start": "node dist/main.js",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "test": "jest --runInBand",
    "test:cov": "jest --coverage --runInBand",
    "prisma:generate": "prisma generate",
    "prisma:validate": "prisma validate",
    "migrate:deploy": "prisma migrate deploy",
    "migrate:dev": "prisma migrate dev",
    "migrate:diff": "prisma migrate diff --from-empty --to-schema-datamodel prisma/schema.prisma --script",
    "clean": "rimraf dist generated .turbo coverage"
  },
  "dependencies": {
    "@nestjs/common": "10.4.4",
    "@nestjs/core": "10.4.4",
    "@nestjs/platform-express": "10.4.4",
    "@prisma/client": "5.20.0",
    "class-transformer": "0.5.1",
    "class-validator": "0.14.1",
    "helmet": "8.0.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.1"
  },
  "devDependencies": {
    "@livraison/eslint-config": "workspace:*",
    "@nestjs/cli": "10.4.5",
    "@nestjs/schematics": "10.1.4",
    "@nestjs/testing": "10.4.4",
    "@types/express": "4.17.21",
    "@types/jest": "29.5.13",
    "@types/node": "20.14.10",
    "eslint": "8.57.1",
    "jest": "29.7.0",
    "prisma": "5.20.0",
    "rimraf": "6.0.1",
    "ts-jest": "29.2.5",
    "ts-loader": "9.5.1",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "5.5.4"
  }
}
