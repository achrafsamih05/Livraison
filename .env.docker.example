# Copy to .env before `docker compose up`. Override every secret for non-dev.

# --- Runtime ---
APP_ENV=dev

# --- PostgreSQL ---
POSTGRES_USER=livraison
POSTGRES_PASSWORD=livraison

# --- JWT (identity service) — use long random values in real environments ---
JWT_ACCESS_SECRET=dev-access-secret-at-least-32-characters
JWT_REFRESH_SECRET=dev-refresh-secret-at-least-32-characters

# --- Tenancy ---
DEFAULT_TENANT_SLUG=demo
ADMIN_TENANT_SLUG=platform
