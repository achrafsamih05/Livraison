# Livraison production environment (single-host Ubuntu deployment).
# Copy to /opt/livraison/.env and replace every value. chmod 600 this file.

# --- Domain (root domain; subdomains derived: merchant., admin., driver., api.) ---
DOMAIN=example.com
ACME_EMAIL=ops@example.com

# --- Container image source ---
REGISTRY_REPO=ghcr.io/your-org/livraison
IMAGE_TAG=v1.0.0

# --- PostgreSQL (internal only; not exposed to the network) ---
POSTGRES_USER=livraison
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# --- JWT secrets (>= 32 chars each; generate with: openssl rand -base64 48) ---
JWT_ACCESS_SECRET=REPLACE_WITH_RANDOM_48_CHARS
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_RANDOM_48_CHARS

# --- Tenancy ---
DEFAULT_TENANT_SLUG=demo
ADMIN_TENANT_SLUG=platform

# --- Backups ---
BACKUP_DIR=/var/backups/livraison
BACKUP_RETENTION_DAYS=14
# Age/GPG recipient public key file for encrypting backups at rest (optional but recommended).
BACKUP_GPG_RECIPIENT=

# --- Monitoring / alerting ---
# Slack-compatible incoming webhook for alerts (optional; logs locally if empty).
ALERT_WEBHOOK_URL=
DISK_ALERT_THRESHOLD_PCT=85
