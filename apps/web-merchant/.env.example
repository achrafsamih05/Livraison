# Upstream Livraison API base URLs (server-side only; never exposed to the browser).
SHIPMENT_API_URL=http://localhost:3002/api/v1
TRACKING_API_URL=http://localhost:3003/api/v1
IDENTITY_API_URL=http://localhost:3001/api/v1

# Session cookie signing/derivation (set a long random value in real envs).
SESSION_SECRET=change-me-session-secret-at-least-32-chars

# Default tenant slug for login (the portal is single-tenant per deployment/domain).
DEFAULT_TENANT_SLUG=demo
